rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }

    // isAdmin() tetap pakai get() — hanya untuk operasi admin absensi yang tidak di-batch.
    // Jangan tambahkan get() ke rules KPI lain karena bisa gagal karena rate-limit Firebase.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(userId) { return isSignedIn() && request.auth.uid == userId; }

    // ==========================================
    // 1. USERS — shared
    // ==========================================
    match /users/{userId} {
      // Siapa pun yang login boleh baca data users (dibutuhkan app KPI dan absensi).
      allow read: if isSignedIn();

      allow create: if isSelf(userId)
        && request.resource.data.role == 'staff'
        && request.resource.data.status == 'pending';

      allow update: if isAdmin()
        || (isSelf(userId) && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deviceConnected']))
        // kpiRole: hanya boleh update orang LAIN (bukan diri sendiri) untuk cegah self-promotion.
        // UI membatasi akses ke menu HR/Employee saja.
        || (!isSelf(userId) && isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['kpiRole', 'managedDepartments']));

      allow delete: if isAdmin();
    }

    // ==========================================
    // 2. ATTENDANCE — absensi app
    // ==========================================
    match /attendance/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSelf(request.resource.data.userId) || isAdmin();
      allow update: if isAdmin()
        || (isSelf(resource.data.userId)
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['checkOut', 'earlyReason']));
      allow delete: if isAdmin();
    }

    // ==========================================
    // 3. REQUESTS — absensi app
    // ==========================================
    match /requests/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSelf(request.resource.data.userId) || isAdmin();
      allow update: if isAdmin()
        || (isSelf(resource.data.userId)
            && (
              (resource.data.status == 'pending'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                && request.resource.data.status == 'cancelled')
              || (resource.data.status == 'approved'
                  && request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['cancellationRequested', 'cancellationReason'])
                  && request.resource.data.cancellationRequested == true)
            ));
      allow delete: if isAdmin();
    }

    // ==========================================
    // 4. SYSTEM & HOLIDAYS — shared
    // ==========================================
    match /system/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /holidays/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // 6. LOGS — absensi app
    // ==========================================
    match /logs/{logId} {
      allow read:           if isSignedIn();
      allow create:         if isAdmin()
        || isSelf(request.resource.data.uid)
        || isSelf(request.resource.data.userId);
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // 7. KPIS — NovaCore
    // Semua operasi pakai isSignedIn() — UI enforce role (HR/Executive/Head).
    // ==========================================
    match /kpis/{kpiId} {
      allow read: if isSignedIn();
      // Create: harus mulai dari status draft.
      allow create: if isSignedIn()
        && request.resource.data.status == 'draft';
      // Update: tidak boleh ubah field identitas inti (periode & pembuat).
      allow update: if isSignedIn()
        && !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['year', 'month', 'createdAt', 'createdBy']);
      // Delete: UI hanya menampilkan tombol delete untuk HR/Executive.
      allow delete: if isSignedIn();
    }

    // ==========================================
    // 8. KPI ASSIGNMENTS — NovaCore
    // ==========================================
    match /kpi_assignments/{assignmentId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      // Delete: UI enforce HR/Executive only.
      allow delete: if isSignedIn();
      // Update: tidak boleh ubah field identitas inti.
      allow update: if isSignedIn()
        && !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['userId', 'kpiId', 'year', 'month', 'createdAt']);
    }

    // ==========================================
    // 9. DAILY REPORTS — NovaCore
    // ==========================================
    match /daily_reports/{reportId} {
      allow read: if isSignedIn();
      // Create: siapa pun yang login boleh submit laporan (untuk diri sendiri atau atas nama orang lain via HR).
      allow create: if isSignedIn();
      // Update: laporan milik sendiri hanya boleh ubah nilai & catatan.
      //         Laporan orang lain boleh ubah apa pun kecuali field identitas inti.
      allow update: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            ? request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['actualValue', 'notes', 'updatedAt'])
            : !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['userId', 'assignmentId', 'date', 'createdAt']));
      // Delete: UI enforce (pemilik atau HR/Executive).
      allow delete: if isSignedIn();
    }

    // ==========================================
    // 10. KPI HISTORIES — immutable, Cloud Functions only
    // ==========================================
    match /kpi_histories/{historyId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ==========================================
    // 11. NOTES — NovaCore
    // ==========================================
    match /notes/{noteId} {
      allow read:           if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete:         if isSignedIn();
    }

    // ==========================================
    // 12. KPI SETTINGS — NovaCore
    // ==========================================
    match /kpi_settings/{userId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ==========================================
    // 13. PERFORMANCE SUMMARIES — Cloud Functions only
    // ==========================================
    match /performance_summaries/{summaryId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ==========================================
    // 14. FEEDBACKS — NovaCore
    // ==========================================
    match /feedbacks/{feedbackId} {
      allow read:           if isSignedIn();
      allow update, delete: if isSignedIn();
      allow create:         if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
